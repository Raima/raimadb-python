{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "args": [
                "discover",
                "-v",
                "-s",
                "tests",
                "-p",
                "test_*.py"
            ],
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Run Current Test File",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "args": [
                "-v",
                "${file}"
            ],
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Run python01 Example",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/examples/python01/python01Example_main.py",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}
